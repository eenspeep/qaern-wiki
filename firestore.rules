rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Articles: any authenticated user can read and write
    match /articles/{articleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Changelog: any authenticated user can read; only authenticated users can create
    match /changelog/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Keeper history: only the speep admin can read/write
    match /keeper_history/{docId} {
      allow read, write: if request.auth != null && request.auth.token.name == 'speep';
    }

    // Bulletin board: all authenticated users can read; only speep can write
    match /bulletin/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.name == 'speep';
    }

    // Adventures log: all authenticated users can read and write
    match /bulletin/adventures {
      allow read, write: if request.auth != null;
    }

    // Initiative tracker: all authenticated users can read and write
    match /initiative/{docId} {
      allow read, write: if request.auth != null;
    }
    // Hex map: all authenticated users can read; only speep can write
    match /hexmap/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.name == 'speep';
    }
  }
}
