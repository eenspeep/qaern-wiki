rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Articles: any authenticated user can read and write
    match /articles/{articleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Changelog: any authenticated user can read; only authenticated users can create
    match /changelog/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Keeper history: only the speep admin can read/write
    match /keeper_history/{docId} {
      allow read, write: if request.auth != null && request.auth.token.name == 'speep';
    }

    // Bulletin board: all authenticated users can read; only speep can write
    match /bulletin/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.name == 'speep';
    }

    // Adventures log: all authenticated users can read and write
    match /bulletin/adventures {
      allow read, write: if request.auth != null;
    }

    // Initiative tracker: all authenticated users can read and write
    match /initiative/{docId} {
      allow read, write: if request.auth != null;
    }
    // Hex map: all authenticated users can read; only speep can write
    match /hexmap/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.name == 'speep';
    }
    // Downtime rolls: all authenticated users can read and create; only speep can update or delete
    match /downtime/{rollId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.token.name == 'speep';
    }
    // Forum chat: categories readable by all auth; only speep creates categories
    // threads and posts: all auth can read; auth users can create; owners + speep can edit/delete
    match /chat/{catId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.token.name == 'speep';

      match /threads/{threadId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null && request.auth.token.name == 'speep';

        match /posts/{postId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null;
          allow update: if request.auth != null &&
            (request.auth.uid == resource.data.uid || request.auth.token.name == 'speep');
          allow delete: if request.auth != null &&
            (request.auth.uid == resource.data.uid || request.auth.token.name == 'speep');
        }
      }
    }
    // People (NPC tracker): all authenticated users can read; only speep can write
    match /people/{personId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.name == 'speep';
    }
    // People category tree
    match /people_meta/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.name == 'speep';
    }
    // Documents hub: all authenticated users can read; only speep can write
    match /documents/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.name == 'speep';
    }
    // Documents category tree: same permissions as documents
    match /documents_meta/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.name == 'speep';
    }
    // User profiles: users can read all, write only their own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
